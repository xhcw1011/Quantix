# ──────────────────────────────────────────────────────────────────
# Quantix environment variables
# Copy this file to deploy/.env and fill in the values before
# running: docker compose -f deploy/docker-compose.yml up
# ──────────────────────────────────────────────────────────────────

# AES-256-GCM key for encrypting API credentials stored in the DB.
# Generate with: openssl rand -hex 32
QUANTIX_ENCRYPTION_KEY=your-64-hex-char-key-here

# Secret used to sign JWT tokens. Use a long random string.
QUANTIX_JWT_SECRET=change-me-to-a-long-random-string

# Set to "true" to enable live trading with real money.
# Leave empty or unset to prevent accidental live trading.
QUANTIX_LIVE_CONFIRM=

# Comma-separated list of allowed CORS origins for the frontend.
# Defaults to localhost dev ports if unset.
QUANTIX_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Telegram bot token and chat ID for trade notifications.
# QUANTIX_TELEGRAM_TOKEN=
# QUANTIX_TELEGRAM_CHAT_ID=
